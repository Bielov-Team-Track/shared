# Digital Ocean Container Registry
DO_REGISTRY_NAME=your-registry-name

# Database connection strings for Digital Ocean managed databases
AUTH_DB_CONNECTION_STRING=Host=your-auth-db-host;Port=25060;Database=volleyer_auth;Username=doadmin;Password=your-auth-db-password;SslMode=Require
EVENTS_DB_CONNECTION_STRING=Host=your-events-db-host;Port=25060;Database=volleyer_events;Username=doadmin;Password=your-events-db-password;SslMode=Require

# JWT configuration
JWT_SECRET_KEY=your-very-long-random-jwt-secret-key-here-minimum-32-characters